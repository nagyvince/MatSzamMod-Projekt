    "import osmnx as ox\n",
    "\n",
    "ox.settings.use_cache = True\n",
    "\n",
    "G = ox.graph_from_place(\n",
    "    \"Budapest, Hungary\",\n",
    "    network_type=\"drive\",\n",
    "    simplify=False\n",
    ")\n",
    "\n",
    "ox.save_graphml(G, \"budapest.graphml\")"
   ]
  }
